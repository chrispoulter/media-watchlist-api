{
    "name": "media-watchlist-api",
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "build": "tsc",
        "start": "node dist/src/server.js",
        "typecheck": "tsc --noEmit",
        "lint": "eslint --cache .",
        "format": "prettier --write .",
        "db:create": "node scripts/db-create.js",
        "db:drop": "node scripts/db-drop.js",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:studio": "drizzle-kit studio",
        "email:dev": "email dev -p 3001 -d src/emails"
    },
    "dependencies": {
        "@react-email/components": "^1.0.12",
        "@react-email/render": "^2.0.7",
        "@scalar/express-api-reference": "^0.9.11",
        "better-auth": "^1.6.9",
        "cors": "^2.8.6",
        "dotenv": "^17.4.2",
        "drizzle-orm": "^0.45.2",
        "express": "^5.2.1",
        "nodemailer": "^8.0.7",
        "pino": "^10.3.1",
        "pino-http": "^11.0.0",
        "postgres": "^3.4.9",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@react-email/preview-server": "^5.2.10",
        "@react-email/ui": "^6.0.1",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/node": "^25.6.0",
        "@types/nodemailer": "^8.0.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "drizzle-kit": "^0.31.10",
        "eslint": "^10.2.1",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.5.0",
        "jiti": "^2.6.1",
        "pino-pretty": "^13.1.3",
        "prettier": "^3.8.3",
        "react-email": "^6.0.1",
        "tsx": "^4.21.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.1"
    }
}
