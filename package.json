{
    "name": "media-watchlist-api",
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc",
        "start": "node dist/src/index.js",
        "typecheck": "tsc --noEmit",
        "lint": "eslint --cache .",
        "format": "prettier --write .",
        "db:create": "node scripts/db-create.js",
        "db:drop": "node scripts/db-drop.js",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:studio": "drizzle-kit studio",
        "email:dev": "email dev -p 3001 -d src/emails"
    },
    "dependencies": {
        "@hono/node-server": "^2.0.4",
        "@hono/zod-validator": "^0.8.0",
        "@react-email/ui": "^6.1.1",
        "@scalar/hono-api-reference": "^0.10.19",
        "better-auth": "^1.6.9",
        "dotenv": "^17.4.2",
        "drizzle-orm": "^0.45.2",
        "hono": "^4.12.23",
        "hono-pino": "^0.10.3",
        "nodemailer": "^8.0.7",
        "pg": "^8.14.1",
        "pino": "^10.3.1",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "react-email": "^6.1.1",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.6.0",
        "@types/nodemailer": "^8.0.0",
        "@types/pg": "^8.11.14",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "drizzle-kit": "^0.31.10",
        "eslint": "^10.2.1",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.5.0",
        "jiti": "^2.6.1",
        "openapi-types": "^12.1.3",
        "pino-pretty": "^13.1.3",
        "prettier": "^3.8.3",
        "tsx": "^4.21.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.1"
    }
}
